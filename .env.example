# Application
APP_BASE_URL=https://ciphershield.securespherelabs.com
NODE_ENV=production
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ciphershield
DB_USER=
DB_PASSWORD=

# Encryption
ENCRYPTION_KEY=          # 32-byte hex string — generate with: openssl rand -hex 32
ENCRYPTION_IV_LENGTH=12  # GCM nonce length

# Authentication
JWT_SECRET=              # generate with: openssl rand -hex 64
JWT_EXPIRY=8h

# AI Layer (internal — do not expose or commit)
AI_PROVIDER_KEY=
AI_PROVIDER_ENDPOINT=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX=5
